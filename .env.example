# Copy to .env and fill in real values. .env is gitignored — never commit it.

# The domain/subdomain pointed at the relay host. Agents and clients
# connect to wss://$DOMAIN — never configure them against a bare IP
# (see ops/beta-tier.md for why this matters for migration).
DOMAIN=relay.example.com

RELAY_PORT=8080

# Redis connection (the beta Compose profile runs this as a sidecar
# container — REDIS_URL should point at the service name, not localhost)
REDIS_URL=redis://redis:6379/0

# Pairing token TTL in seconds — see SECURITY.md's Pairing Model
PAIRING_TOKEN_TTL=120
