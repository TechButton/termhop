DOMAIN=relay.example.com
RELAY_PORT=8080
REDIS_URL=redis://redis:6379/0
PAIRING_TOKEN_TTL=120
PROTOCOL_VERSION=2
# Required, no default: the exact HTTPS origin(s) of the browser client(s)
# you operate that are allowed to open WebSockets to this relay.
CLIENT_ORIGINS=https://your-client-domain.example
HANDSHAKE_TIMEOUT_S=20
TERMHOP_RELEASE=development
# Comma-separated addresses of your TLS reverse proxy, as seen by the relay
# process itself (e.g. the docker network gateway IP, found with
# `docker network inspect <compose-project>_default`). Leave empty (default)
# to trust only the raw connecting peer address, never X-Forwarded-For.
TRUSTED_PROXY_IPS=
# Concurrent WebSocket connections allowed from a single (post-proxy) IP
# before new connections from it are refused, to bound resource exhaustion.
MAX_CONNECTIONS_PER_IP=40
