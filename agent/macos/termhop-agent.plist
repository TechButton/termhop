<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.termhop.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>__EXEC_PATH__</string>
        <string>pair</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/termhop-agent.out.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/termhop-agent.err.log</string>
</dict>
</plist>
